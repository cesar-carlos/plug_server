generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum UserStatus {
  pending
  active
  rejected
  blocked
}

enum ClientStatus {
  pending
  active
  blocked
}

enum AgentStatus {
  active
  inactive
}

enum AgentDocumentType {
  cpf
  cnpj
}

enum ClientAgentAccessRequestStatus {
  pending
  approved
  rejected
  expired
}

model User {
  id              String          @id @default(uuid())
  email           String          @unique @db.VarChar(255)
  /// Brazilian mobile (E.164), optional; unique when set (PostgreSQL allows multiple NULL)
  celular         String?         @unique @map("celular") @db.VarChar(20)
  passwordHash    String          @map("password_hash")
  role            UserRole        @default(user)
  status          UserStatus      @default(pending) @map("status")
  createdAt       DateTime        @default(now()) @map("created_at")
  refreshTokens   RefreshToken[]
  agentIdentities AgentIdentity[]
  lastLoginAgents Agent[]         @relation("AgentLastLoginUser")
  registrationApprovalToken RegistrationApprovalToken?
  clients         Client[]

  @@map("users")
}

model Client {
  id          String                   @id @default(uuid())
  userId      String                   @map("user_id")
  user        User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email       String                   @unique @db.VarChar(255)
  passwordHash String                  @map("password_hash")
  name        String                   @db.VarChar(120)
  lastName    String                   @map("last_name") @db.VarChar(120)
  mobile      String?                  @db.VarChar(20)
  status      ClientStatus             @default(pending)
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @updatedAt @map("updated_at")
  refreshTokens ClientRefreshToken[]
  agentAccesses ClientAgentAccess[]
  agentAccessRequests ClientAgentAccessRequest[]
  registrationApprovalToken ClientRegistrationApprovalToken?

  @@index([userId])
  @@index([status])
  @@map("clients")
}

model ClientRefreshToken {
  id        String    @id
  clientId  String    @map("client_id")
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([clientId])
  @@index([expiresAt])
  @@map("client_refresh_tokens")
}

model ClientRegistrationApprovalToken {
  id        String   @id @db.VarChar(128)
  clientId  String   @unique @map("client_id")
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("client_registration_approval_tokens")
}

model RegistrationApprovalToken {
  id        String   @id @db.VarChar(128)
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("registration_approval_tokens")
}

model RegistrationEmailOutbox {
  id         String   @id @default(uuid())
  kind       String   @db.VarChar(80)
  payload    Json     @map("payload_json")
  attempts   Int      @default(0)
  availableAt DateTime @default(now()) @map("available_at")
  lockedAt   DateTime? @map("locked_at")
  lastError  String?  @map("last_error") @db.VarChar(1000)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([availableAt])
  @@index([lockedAt])
  @@map("registration_email_outbox")
}

model RefreshToken {
  id        String    @id
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Agent {
  agentId          String             @id @map("agent_id") @db.VarChar(36)
  name             String             @db.VarChar(120)
  tradeName        String?            @map("trade_name") @db.VarChar(120)
  document         String?            @unique @db.VarChar(20)
  documentType     AgentDocumentType? @map("document_type")
  phone            String?            @db.VarChar(20)
  mobile           String?            @db.VarChar(20)
  email            String?            @db.VarChar(255)
  street           String?            @db.VarChar(120)
  number           String?            @db.VarChar(20)
  district         String?            @db.VarChar(120)
  postalCode       String?            @map("postal_code") @db.VarChar(20)
  city             String?            @db.VarChar(120)
  state            String?            @db.VarChar(2)
  notes            String?            @db.VarChar(2000)
  profileUpdatedAt DateTime?          @map("profile_updated_at")
  lastLoginUserId  String?            @map("last_login_user_id")
  lastLoginUser    User?              @relation("AgentLastLoginUser", fields: [lastLoginUserId], references: [id], onDelete: SetNull)
  status           AgentStatus        @default(active)
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  agentIdentities  AgentIdentity[]
  clientAccesses   ClientAgentAccess[]
  clientAccessRequests ClientAgentAccessRequest[]

  @@index([lastLoginUserId])

  @@map("agents")
}

model ClientAgentAccess {
  clientId   String   @map("client_id")
  agentId    String   @map("agent_id")
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  agent      Agent    @relation(fields: [agentId], references: [agentId], onDelete: Restrict, onUpdate: Cascade)
  createdAt  DateTime @default(now()) @map("created_at")
  approvedAt DateTime @default(now()) @map("approved_at")

  @@id([clientId, agentId])
  @@index([agentId])
  @@map("client_agent_accesses")
}

model ClientAgentAccessRequest {
  id         String                           @id @default(uuid())
  clientId   String                           @map("client_id")
  agentId    String                           @map("agent_id")
  status     ClientAgentAccessRequestStatus   @default(pending)
  requestedAt DateTime                        @default(now()) @map("requested_at")
  decidedAt  DateTime?                        @map("decided_at")
  decisionReason String?                      @map("decision_reason") @db.VarChar(500)
  createdAt  DateTime                         @default(now()) @map("created_at")
  updatedAt  DateTime                         @updatedAt @map("updated_at")
  client     Client                           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  agent      Agent                            @relation(fields: [agentId], references: [agentId], onDelete: Restrict, onUpdate: Cascade)
  approvalToken ClientAgentAccessApprovalToken?

  @@unique([clientId, agentId], map: "client_agent_access_requests_client_id_agent_id_key")
  @@index([agentId])
  @@index([status])
  @@index([clientId, requestedAt])
  @@index([clientId, status, requestedAt])
  @@map("client_agent_access_requests")
}

model ClientAgentAccessApprovalToken {
  id         String                  @id @db.VarChar(128)
  requestId  String                  @unique @map("request_id")
  request    ClientAgentAccessRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  expiresAt  DateTime                @map("expires_at")
  createdAt  DateTime                @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("client_agent_access_approval_tokens")
}

model AgentIdentity {
  agentId   String   @id @map("agent_id")
  userId    String   @map("user_id")
  agent     Agent    @relation(fields: [agentId], references: [agentId], onDelete: Restrict, onUpdate: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("agent_identities")
}

model AuditEvent {
  id            String   @id
  eventType     String   @map("event_type") @db.VarChar(120)
  actorSocketId String?  @map("actor_socket_id")
  actorUserId   String?  @map("actor_user_id")
  actorRole     String?  @map("actor_role") @db.VarChar(40)
  direction     String?  @db.VarChar(40)
  conversationId String? @map("conversation_id")
  agentId       String?  @map("agent_id")
  requestId     String?  @map("request_id")
  streamId      String?  @map("stream_id")
  traceId       String?  @map("trace_id")
  payloadJson   Json?    @map("payload_json")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([agentId])
  @@index([requestId])
  @@index([streamId])
  @@map("audit_events")
}

model BridgeLatencyTrace {
  id              String   @id @default(uuid())
  channel         String   @db.VarChar(32)
  requestId       String   @map("request_id") @db.VarChar(128)
  traceId         String?  @map("trace_id") @db.VarChar(64)
  agentId         String   @map("agent_id") @db.VarChar(128)
  userId          String?  @map("user_id") @db.VarChar(128)
  jsonRpcMethod   String?  @map("json_rpc_method") @db.VarChar(120)
  totalMs              Int      @map("total_ms")
  phasesSumMs          Int      @default(0) @map("phases_sum_ms")
  phasesSchemaVersion  Int      @default(1) @map("phases_schema_version")
  phasesMs             Json     @map("phases_ms")
  outcome              String   @db.VarChar(32)
  httpStatus      Int?     @map("http_status")
  errorCode       String?  @map("error_code") @db.VarChar(64)
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([agentId, createdAt])
  @@index([channel, createdAt])
  @@index([outcome, createdAt])
  @@map("bridge_latency_traces")
}
