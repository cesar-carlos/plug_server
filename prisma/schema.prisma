generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

model User {
  id              String          @id @default(uuid())
  email           String          @unique @db.VarChar(255)
  passwordHash    String          @map("password_hash")
  role            UserRole        @default(user)
  createdAt       DateTime        @default(now()) @map("created_at")
  refreshTokens   RefreshToken[]
  agentIdentities AgentIdentity[]

  @@map("users")
}

model RefreshToken {
  id        String    @id
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model AgentIdentity {
  agentId   String   @id @map("agent_id")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("agent_identities")
}

model AuditEvent {
  id            String   @id
  eventType     String   @map("event_type") @db.VarChar(120)
  actorSocketId String?  @map("actor_socket_id")
  actorUserId   String?  @map("actor_user_id")
  actorRole     String?  @map("actor_role") @db.VarChar(40)
  direction     String?  @db.VarChar(40)
  conversationId String? @map("conversation_id")
  agentId       String?  @map("agent_id")
  requestId     String?  @map("request_id")
  streamId      String?  @map("stream_id")
  traceId       String?  @map("trace_id")
  payloadJson   Json?    @map("payload_json")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([agentId])
  @@index([requestId])
  @@index([streamId])
  @@map("audit_events")
}

model BridgeLatencyTrace {
  id              String   @id @default(uuid())
  channel         String   @db.VarChar(32)
  requestId       String   @map("request_id") @db.VarChar(128)
  traceId         String?  @map("trace_id") @db.VarChar(64)
  agentId         String   @map("agent_id") @db.VarChar(128)
  userId          String?  @map("user_id") @db.VarChar(128)
  jsonRpcMethod   String?  @map("json_rpc_method") @db.VarChar(120)
  totalMs              Int      @map("total_ms")
  phasesSumMs          Int      @default(0) @map("phases_sum_ms")
  phasesSchemaVersion  Int      @default(1) @map("phases_schema_version")
  phasesMs             Json     @map("phases_ms")
  outcome              String   @db.VarChar(32)
  httpStatus      Int?     @map("http_status")
  errorCode       String?  @map("error_code") @db.VarChar(64)
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([agentId, createdAt])
  @@index([channel, createdAt])
  @@index([outcome, createdAt])
  @@map("bridge_latency_traces")
}
