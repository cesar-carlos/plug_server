APP_NAME=plug_server
NODE_ENV=development
PORT=3000
CORS_ORIGIN=*
REQUEST_BODY_LIMIT=1mb
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/plug_server?schema=public
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=plug_server
POSTGRES_PORT=5432

# Access token — short-lived (15m recommended for production)
JWT_ACCESS_SECRET=change-me-access-development
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token — long-lived (7d recommended for production)
JWT_REFRESH_SECRET=change-me-refresh-development
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=plug_server
JWT_AUDIENCE=plug_clients

# Optional PayloadFrame signature verification (HMAC-SHA256).
# If PAYLOAD_SIGNING_KEY is set, signed socket frames are verified.
PAYLOAD_SIGNING_KEY=
PAYLOAD_SIGNING_KEY_ID=

SOCKET_AUTH_REQUIRED=true
# Comma-separated roles allowed in /agents (default: agent)
SOCKET_AGENT_ROLES=agent
# Comma-separated roles allowed in /consumers (default: user,admin)
SOCKET_CONSUMER_ROLES=user,admin
# Relay reliability and performance controls
SOCKET_RELAY_REQUEST_TIMEOUT_MS=15000
SOCKET_RELAY_CONVERSATION_IDLE_TIMEOUT_MS=300000
SOCKET_RELAY_CONVERSATION_SWEEP_INTERVAL_MS=60000
SOCKET_RELAY_MAX_CONVERSATIONS=5000
SOCKET_RELAY_MAX_CONVERSATIONS_PER_CONSUMER=20
SOCKET_RELAY_MAX_PENDING_REQUESTS=10000
SOCKET_RELAY_MAX_PENDING_REQUESTS_PER_CONVERSATION=32
SOCKET_RELAY_MAX_PENDING_REQUESTS_PER_CONSUMER=128
SOCKET_RELAY_MAX_ACTIVE_STREAMS=5000
SOCKET_RELAY_MAX_BUFFERED_CHUNKS_PER_REQUEST=100
SOCKET_RELAY_MAX_TOTAL_BUFFERED_CHUNKS=10000
SOCKET_RELAY_IDEMPOTENCY_TTL_MS=300000
SOCKET_RELAY_CIRCUIT_FAILURE_THRESHOLD=5
SOCKET_RELAY_CIRCUIT_OPEN_MS=30000
SOCKET_RELAY_METRICS_LOG_INTERVAL_MS=60000
SOCKET_RELAY_RATE_LIMIT_WINDOW_MS=10000
SOCKET_RELAY_RATE_LIMIT_MAX_CONVERSATION_STARTS=8
SOCKET_RELAY_RATE_LIMIT_MAX_REQUESTS=40
# REST bridge pending correlation budget (single + batch with IDs)
SOCKET_REST_MAX_PENDING_REQUESTS=10000
# REST bridge per-agent overload controls (short queue + fail-fast)
SOCKET_REST_AGENT_MAX_INFLIGHT=8
SOCKET_REST_AGENT_MAX_QUEUE=16
SOCKET_REST_AGENT_QUEUE_WAIT_MS=150
# Audit retention policy for socket events (default: 90 days, run every 1440 minutes)
SOCKET_AUDIT_RETENTION_DAYS=90
SOCKET_AUDIT_RETENTION_INTERVAL_MINUTES=1440
SOCKET_AUDIT_PRUNE_BATCH_SIZE=5000

SWAGGER_ENABLED=true
