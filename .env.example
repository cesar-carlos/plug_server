APP_NAME=plug_server
NODE_ENV=development
PORT=3000
CORS_ORIGIN=*
REQUEST_BODY_LIMIT=1mb
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/plug_server?schema=public
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=plug_server
POSTGRES_PORT=5432

# Access token — short-lived (15m recommended for production)
JWT_ACCESS_SECRET=change-me-access-development
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token — long-lived (7d recommended for production)
JWT_REFRESH_SECRET=change-me-refresh-development
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=plug_server
JWT_AUDIENCE=plug_clients
SOCKET_AUTH_REQUIRED=true

SWAGGER_ENABLED=true
