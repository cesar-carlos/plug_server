APP_NAME=plug_server
NODE_ENV=development
PORT=3000
CORS_ORIGIN=*
REQUEST_BODY_LIMIT=1mb
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/plug_server?schema=public
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=plug_server
POSTGRES_PORT=5432

# Access token — short-lived (15m recommended for production)
JWT_ACCESS_SECRET=change-me-access-development
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token — long-lived (7d recommended for production)
JWT_REFRESH_SECRET=change-me-refresh-development
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=plug_server
JWT_AUDIENCE=plug_clients

# Optional PayloadFrame signature verification (HMAC-SHA256).
# If PAYLOAD_SIGNING_KEY is set, signed socket frames are verified.
PAYLOAD_SIGNING_KEY=
PAYLOAD_SIGNING_KEY_ID=
# When true, hub signs outbound PayloadFrames (requires PAYLOAD_SIGNING_KEY).
PAYLOAD_SIGN_OUTBOUND=false
# Max UTF-8 bytes of JSON before hub tries gzip (default 512 KiB). Larger → cmp:none until 10 MiB frame cap.
PAYLOAD_FRAME_MAX_GZIP_INPUT_BYTES=524288
# Optional zlib level 1–9 for hub PayloadFrame gzip. If unset: NODE_ENV=production → 3 (faster CPU); else Node default (~6).
# PAYLOAD_FRAME_GZIP_LEVEL=
# In auto mode, only keep gzip when the savings beat this many bytes (avoids CPU cost for marginal wins).
PAYLOAD_FRAME_AUTO_GZIP_MIN_SAVINGS_BYTES=64
# Hub→agent bridge: async zlib gzip for eligible JSON at least this many UTF-8 bytes (0 = always sync gzip).
PAYLOAD_FRAME_ASYNC_GZIP_MIN_UTF8_BYTES=131072
# Inbound gzip: async gunzip for compressed PayloadFrame at least this many bytes (0 = always sync).
PAYLOAD_FRAME_ASYNC_GUNZIP_MIN_COMPRESSED_BYTES=65536
# Max offline agent IDs remembered for REST 404 vs 503 (0 = unlimited).
SOCKET_AGENT_KNOWN_IDS_MAX=0
# Grace window after agent:register before first dispatch; heartbeat clears it early.
SOCKET_AGENT_PROTOCOL_READY_GRACE_MS=100

SOCKET_AUTH_REQUIRED=true
# Comma-separated roles allowed in /agents (default: agent)
SOCKET_AGENT_ROLES=agent
# Comma-separated roles allowed in /consumers (default: user,admin)
SOCKET_CONSUMER_ROLES=user,admin
# Engine.IO: max packet size (bytes). Default 10 MiB = PayloadFrame compressed ceiling.
SOCKET_IO_MAX_HTTP_BUFFER_BYTES=10485760
# false = disable WS permessage-deflate (PayloadFrame already does optional gzip)
SOCKET_IO_PER_MESSAGE_DEFLATE=false
# Comma-separated: websocket, polling. If unset: NODE_ENV=production → websocket only; else websocket,polling.
SOCKET_IO_TRANSPORTS=websocket,polling
# false = do not serve socket.io client JS from this server (recommended for API hub)
SOCKET_IO_SERVE_CLIENT=false
# Engine.IO gzip for polling. If unset: NODE_ENV=production → false; else true. Set true if you use polling.
SOCKET_IO_HTTP_COMPRESSION=true
# Optional heartbeat tuning (ms). Defaults: pingInterval 25000, pingTimeout 20000 if unset.
# SOCKET_IO_PING_INTERVAL_MS=
# SOCKET_IO_PING_TIMEOUT_MS=
# Relay reliability and performance controls
SOCKET_RELAY_REQUEST_TIMEOUT_MS=15000
SOCKET_RELAY_CONVERSATION_IDLE_TIMEOUT_MS=300000
SOCKET_RELAY_CONVERSATION_SWEEP_INTERVAL_MS=60000
SOCKET_RELAY_MAX_CONVERSATIONS=5000
SOCKET_RELAY_MAX_CONVERSATIONS_PER_CONSUMER=20
SOCKET_RELAY_MAX_PENDING_REQUESTS=10000
SOCKET_RELAY_MAX_PENDING_REQUESTS_PER_CONVERSATION=32
SOCKET_RELAY_MAX_PENDING_REQUESTS_PER_CONSUMER=128
SOCKET_RELAY_MAX_ACTIVE_STREAMS=5000
SOCKET_RELAY_MAX_BUFFERED_CHUNKS_PER_REQUEST=256
SOCKET_RELAY_MAX_TOTAL_BUFFERED_CHUNKS=25600
SOCKET_RELAY_IDEMPOTENCY_TTL_MS=300000
# Interval between background prunes of relay idempotency maps (larger = less CPU)
SOCKET_RELAY_IDEMPOTENCY_CLEANUP_INTERVAL_MS=120000
SOCKET_RELAY_CIRCUIT_FAILURE_THRESHOLD=5
SOCKET_RELAY_CIRCUIT_OPEN_MS=30000
SOCKET_RELAY_METRICS_LOG_INTERVAL_MS=60000
SOCKET_RELAY_OUTBOUND_TAIL_STALE_MS=300000
SOCKET_RELAY_OUTBOUND_SWEEP_INTERVAL_MS=60000
# 0 disables overload shedding by that signal.
SOCKET_RELAY_OUTBOUND_OVERLOAD_BACKLOG=200
SOCKET_RELAY_OUTBOUND_OVERLOAD_P95_MS=250
SOCKET_RELAY_RATE_LIMIT_WINDOW_MS=10000
SOCKET_RELAY_RATE_LIMIT_MAX_CONVERSATION_STARTS=8
SOCKET_RELAY_RATE_LIMIT_MAX_REQUESTS=64
SOCKET_RELAY_RATE_LIMIT_MAX_STREAM_PULL_CREDITS=1000
SOCKET_CONNECTION_READY_COMPAT_MODE=payload_frame
# REST bridge pending correlation budget (single + batch with IDs)
SOCKET_REST_MAX_PENDING_REQUESTS=10000
# REST bridge per-agent overload controls (short queue + fail-fast)
# REST per-agent parallelism and queue (higher inflight = more concurrent commands per agent)
SOCKET_REST_AGENT_MAX_INFLIGHT=32
SOCKET_REST_AGENT_MAX_QUEUE=64
SOCKET_REST_AGENT_QUEUE_WAIT_MS=200
# Window size for internal rpc:stream.pull when REST materializes streaming sql.execute (larger = fewer pulls, more RAM per stream)
SOCKET_REST_STREAM_PULL_WINDOW_SIZE=256
# REST materialization guardrails for streaming sql.execute (stream_id + chunks). Rows=0 disables row cap (not recommended).
SOCKET_REST_SQL_STREAM_MATERIALIZE_MAX_ROWS=1000000
# Chunk frames during materialization; 0 = unlimited (prefer Socket bridge for huge streams).
SOCKET_REST_SQL_STREAM_MATERIALIZE_MAX_CHUNKS=0
# Audit retention policy for socket events (default: 90 days, run every 1440 minutes)
SOCKET_AUDIT_RETENTION_DAYS=90
SOCKET_AUDIT_RETENTION_INTERVAL_MINUTES=1440
SOCKET_AUDIT_PRUNE_BATCH_SIZE=5000
# Batched socket audit inserts (1 = legacy single INSERT per event; >1 groups into one transaction)
SOCKET_AUDIT_BATCH_MAX=48
SOCKET_AUDIT_BATCH_FLUSH_MS=200
# Percent of relay:rpc.chunk audit rows persisted. If unset: NODE_ENV=production → 25; else 100.
SOCKET_AUDIT_HIGH_VOLUME_SAMPLE_PERCENT=100

# Optional: PostgreSQL rows with per-phase timings for REST, consumer agents:command, and relay (see docs/observability.md).
BRIDGE_LATENCY_TRACE_ENABLED=false
# Random sample % for fast successful commands; errors/timeouts always persisted when tracing is on.
BRIDGE_LATENCY_TRACE_SAMPLE_PERCENT=100
# Also persist when total wall time (ms) is >= this (0 = off).
BRIDGE_LATENCY_TRACE_SLOW_TOTAL_MS=0
BRIDGE_LATENCY_TRACE_BATCH_MAX=48
BRIDGE_LATENCY_TRACE_BATCH_FLUSH_MS=200
# Max in-memory queued rows before dropping (0 = unlimited).
BRIDGE_LATENCY_TRACE_MAX_QUEUE=0
BRIDGE_LATENCY_TRACE_RETENTION_DAYS=90
BRIDGE_LATENCY_TRACE_RETENTION_INTERVAL_MINUTES=1440
BRIDGE_LATENCY_TRACE_PRUNE_BATCH_SIZE=5000
# OpenTelemetry span per command (requires a globally configured tracer).
BRIDGE_LATENCY_TRACE_OTEL_ENABLED=false
# Warn when |total_ms - phases_sum_ms| exceeds this (0 = off). Increments plug_bridge_latency_trace_phases_mismatch_total.
BRIDGE_LATENCY_TRACE_PHASES_MISMATCH_WARN_MS=0
# true = do not persist user_id in bridge_latency_traces (PII reduction in DB + traces path).
BRIDGE_LATENCY_TRACE_REDACT_USER_ID=false
# Max characters of request_id to store (0 = full string).
BRIDGE_LATENCY_TRACE_TRUNCATE_REQUEST_ID_CHARS=0
# Retention days for channel=relay only; leave empty to use BRIDGE_LATENCY_TRACE_RETENTION_DAYS.
# BRIDGE_LATENCY_TRACE_RELAY_RETENTION_DAYS=

# REST POST /api/v1/agents/commands — rate limit (same window for both when IP limit enabled)
REST_AGENTS_COMMANDS_RATE_LIMIT_WINDOW_MS=60000
REST_AGENTS_COMMANDS_RATE_LIMIT_MAX=100
# 0 = per-IP limiter off; use e.g. 300 behind shared NAT (enable Express trust proxy for req.ip)
REST_AGENTS_COMMANDS_RATE_LIMIT_IP_MAX=0

# E2E (npm run test:e2e) — full HTTP + Socket.IO; see tests/e2e/ and docs/e2e_benchmark_hub_agent.md
# When not "true", the script exits 0 without running Vitest (safe for default dev/CI).
# When "true": same stack as a dev server — DATABASE_URL must reach a running Postgres (auth/register uses Prisma).
E2E_TESTS_ENABLED=false

SWAGGER_ENABLED=true

# =============================================================================
# Performance presets (optional) — copy lines into your .env; see docs/performance_hub_agent.md
# =============================================================================
# High throughput: larger stream window + relay chunk buffers (more RAM):
# SOCKET_REST_STREAM_PULL_WINDOW_SIZE=512
# SOCKET_RELAY_MAX_BUFFERED_CHUNKS_PER_REQUEST=512
# SOCKET_RELAY_MAX_TOTAL_BUFFERED_CHUNKS=51200
#
# Earlier async zlib (large/medium compressed traffic):
# PAYLOAD_FRAME_ASYNC_GZIP_MIN_UTF8_BYTES=65536
# PAYLOAD_FRAME_ASYNC_GUNZIP_MIN_COMPRESSED_BYTES=32768
#
# Try gzip on larger hub→agent JSON (more CPU; up to 10 MiB frame cap):
# PAYLOAD_FRAME_MAX_GZIP_INPUT_BYTES=1048576
#
# Small VM: fewer async zlib calls + less frequent idempotency sweep:
# PAYLOAD_FRAME_ASYNC_GZIP_MIN_UTF8_BYTES=262144
# PAYLOAD_FRAME_ASYNC_GUNZIP_MIN_COMPRESSED_BYTES=131072
# SOCKET_RELAY_IDEMPOTENCY_CLEANUP_INTERVAL_MS=180000
